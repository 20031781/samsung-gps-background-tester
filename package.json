{
  "name": "samsung-gps-background-tester",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "go": "expo start --go",
    "dev-build": "expo run:android --device",
    "release-build": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-release-local.ps1",
    "start": "npm run go",
    "android": "npm run dev-build",
    "ios": "expo run:ios",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.12",
    "expo": "^55.0.4",
    "expo-application": "~55.0.8",
    "expo-battery": "~55.0.8",
    "expo-device": "~55.0.9",
    "expo-file-system": "~55.0.10",
    "expo-intent-launcher": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-location": "~55.1.2",
    "expo-notifications": "~55.0.10",
    "expo-sharing": "~55.0.11",
    "expo-sqlite": "~55.0.10",
    "expo-task-manager": "~55.0.9",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-get-random-values": "^1.11.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-universe": "^13.0.0",
    "typescript": "~5.9.2"
  }
}
